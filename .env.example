# Vigilo configuration
# Copy to .env and adjust as needed: cp .env.example .env

# Path to the conn.log to analyze (inside the container: /app/data/...)
VIGILO_LOG=data/home/home.conn.log

# Path to the trained model checkpoint
VIGILO_CKPT=checkpoints/vigilo/vigilo.pt

# Dashboard bind address and port
VIGILO_HOST=0.0.0.0
VIGILO_PORT=8088

# Gunicorn tuning
VIGILO_WORKERS=2
VIGILO_TIMEOUT=120
