# Vigilo configuration
# Copy to .env and adjust as needed: cp .env.example .env

# Path to the conn.log to analyze (inside the container: /app/data/...)
VIGILO_LOG=data/home/home.conn.log

# Path to the trained model checkpoint
VIGILO_CKPT=checkpoints/vigilo/vigilo.pt

# Dashboard bind address and port
VIGILO_HOST=0.0.0.0
VIGILO_PORT=8088

# Gunicorn tuning
VIGILO_WORKERS=2
VIGILO_TIMEOUT=120

# --- Wi-Fi / MITM capture tooling (scripts/) ----------------------------------
# ONLY for a network you own and devices you are authorized to monitor.
# Read by scripts/*.sh. .env is gitignored — never commit your real values.
WIFI_SSID="YOUR_SSID"
WIFI_PASS="YOUR_WIFI_PASSWORD"
WIFI_CHANNEL=1
CAPTURE_IFACE=wlan0
CAPTURE_SUBNET=192.168.1.0/24
# space-separated UPPERCASE MACs of YOUR OWN devices (AP BSSIDs / phone MACs)
CAPTURE_BSSIDS=""
CAPTURE_PHONE_MACS=""
