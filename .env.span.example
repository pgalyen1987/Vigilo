# Vigilo — passive SPAN / gateway deployment
# Copy to .env when using: docker compose --profile span up -d
# See docs/DEPLOY-SPAN-GATEWAY.md

# Network interface receiving mirrored (SPAN) traffic on the capture host
CAPTURE_IFACE=eth1

# Zeek writes conn.log here; Vigilo reads it
VIGILO_LOG=data/zeek/conn.log

# Demo checkpoint works out of the box; replace after training on YOUR benign traffic
VIGILO_CKPT=checkpoints/demo/vigilo.pt

VIGILO_HOST=0.0.0.0
VIGILO_PORT=8088
VIGILO_WORKERS=2
VIGILO_TIMEOUT=120
